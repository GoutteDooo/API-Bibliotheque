@model IEnumerable<Brief_Bibliotheque.Models.Classes.Reservation>

@{
    ViewData["Title"] = "Index";
}

<h1>Les Réservations</h1>

<p>
    <a asp-action="Create">Nouvelle Réservation</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Id)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DateReservation)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EstTermine)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdUtilisateur)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Utilisateur.Nom)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdLivre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Livre.Titre)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Id)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.DateReservation)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.EstTermine)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.IdUtilisateur)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Utilisateur.Nom)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.IdLivre)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Livre.Titre)
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
