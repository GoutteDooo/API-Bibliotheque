@model Brief_Bibliotheque.Models.Classes.Livres
@using Brief_Bibliotheque.Models.Classes

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Livres</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Isbn" class="control-label"></label>
                <input asp-for="Isbn" class="form-control" />
                <span asp-validation-for="Isbn" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Titre" class="control-label"></label>
                <input asp-for="Titre" class="form-control" />
                <span asp-validation-for="Titre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AnneePublication" class="control-label"></label>
                <input asp-for="AnneePublication" class="form-control" />
                <span asp-validation-for="AnneePublication" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Etat" class="control-label"></label>
                <input asp-for="Etat" class="form-control" />
                <span asp-validation-for="Etat" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="EstEmprunter" /> @Html.DisplayNameFor(model => model.EstEmprunter)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="EstReserve" /> @Html.DisplayNameFor(model => model.EstReserve)
                </label>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="EstDisponible" /> @Html.DisplayNameFor(model => model.EstDisponible)
                </label>
            </div>
            <!-- Section pour sélectionner les genres -->
            <div class="form-group">
                <label>Genres</label>
                <div style="max-height: 200px; overflow-y: auto; border: 1px solid #ddd; padding: 10px; margin-top: 5px;">
                    @if (ViewBag.Genres != null)
                    {
                        @foreach (var genre in (List<Genres>)ViewBag.Genres)
                        {
                            <div class="form-check">
                                <input type="checkbox"
                                       name="selectedGenres"
                                       value="@genre.Id"
                                       class="form-check-input"
                                       id="genre_@genre.Id" />
                                <label class="form-check-label" for="genre_@genre.Id">
                                    @genre.NomGenres
                                </label>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- Section pour sélectionner les auteurs -->
            <div class="form-group">
                <label>Auteurs</label>
                <div style="max-height: 200px; overflow-y: auto; border: 1px solid #ddd; padding: 10px; margin-top: 5px;">
                    @if (ViewBag.Auteurs != null)
                    {
                        @foreach (var auteur in (List<Brief_Bibliotheque.Models.Classes.Auteurs>)ViewBag.Auteurs)
                        {
                            <div class="form-check">
                                <input type="checkbox"
                                       name="selectedAuteurs"
                                       value="@auteur.Id"
                                       class="form-check-input"
                                       id="auteur_@auteur.Id" />
                                <label class="form-check-label" for="auteur_@auteur.Id">
                                    @auteur.Nom
                                </label>
                            </div>
                        }
                    }
                </div>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
