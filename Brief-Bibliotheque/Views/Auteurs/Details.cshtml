@model Brief_Bibliotheque.Models.Classes.Auteur

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Auteurs</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nom)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nom)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Prenom)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Prenom)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DateDeNaissance)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DateDeNaissance)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Livres)
        </dt>
        <dd class="col-sm-10">
            @{
                var livresTries = Model.Livres.OrderBy(l => l.AnneePublication).ToList();
            }
            @foreach (var livre in livresTries)
            {
                if (livre.EstDisponible == true){
                <span> @livre.AnneePublication @livre.Titre, Disponible</span>
                    <br />
                }
                else if (livre.EstEmprunte || livre.EstReserve)
                {
                    <span> @livre.AnneePublication @livre.Titre, Indisponible </span>
                    <br />
                }
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>
