@model IEnumerable<Brief_Bibliotheque.Models.Classes.Auteur>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    @if (User.IsInRole("Administrateur") || User.IsInRole("Employé"))
    {
        <a asp-action="Create">Nouvel Auteur</a>
    }
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Nom)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Prenom)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DateDeNaissance)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Nom)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Prenom)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DateDeNaissance)
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id">Détails</a>
                @if (User.IsInRole("Employé") || User.IsInRole("Administrateur"))
                {
                    <span>|</span> <a asp-action="Edit" asp-route-id="@item.Id">Editer</a> <span>|</span>
                    <a asp-action="Delete" asp-route-id="@item.Id">Supprimer</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>
